class Product:
    def __init__(self, pid, name, qty, price):
        self.pid = pid
        self.name = name
        self.qty = qty
        self.price = price

    def update(self, q):
        self.qty += q

    def __str__(self):
        return f"{self.pid} | {self.name} | {self.qty} | {self.price}"


class Inventory:
    def __init__(self):
        self.products = {}

    def add_product(self, pid, name, qty, price):
        if pid in self.products:
            self.products[pid].update(qty)
        else:
            self.products[pid] = Product(pid, name, qty, price)

    def update_product(self, pid, qty):
        if pid in self.products:
            self.products[pid].update(qty)
            print("Updated")
        else:
            print("Not found")

    def display(self):
        if not self.products:
            print("No products")
            return
        for p in self.products.values():
            print(p)


def main():
    inv = Inventory()
    while True:
        print("\n1 Add\n2 Display\n3 Update\n4 Exit")
        choice = input()

        if choice == "1":
            pid = int(input())
            name = input()
            qty = int(input())
            price = float(input())
            inv.add_product(pid, name, qty, price)

        elif choice == "2":
            inv.display()

        elif choice == "3":
            pid = int(input())
            qty = int(input())
            inv.update_product(pid, qty)

        elif choice == "4":
            break


if __name__ == "__main__":
    main()
